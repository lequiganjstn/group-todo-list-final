<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="solo_todo_list.Views.EditTaskPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Edit Task">

    <VerticalStackLayout Margin="20" Spacing="20">
        <Entry x:Name="TitleEntry" Placeholder="Title" />
        <Entry x:Name="DetailsEntry" Placeholder="Details" />

        <Button
            x:Name="UpdateBtn"
            Clicked="UpdateBtn_Clicked"
            Text="Update" />
        <Button
            x:Name="CompleteBtn"
            Clicked="CompleteBtn_Clicked"
            Text="Complete" />
        <Button
            x:Name="DeleteBtn"
            Clicked="DeleteBtn_Clicked"
            Text="Delete" />
    </VerticalStackLayout>
</ContentPage>