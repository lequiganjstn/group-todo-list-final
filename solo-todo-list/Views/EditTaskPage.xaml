<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="solo_todo_list.Views.EditTaskPage">
    <VerticalStackLayout Margin="20" Spacing="20">
        <Entry x:Name="TitleEntry" Placeholder="Title"/>
        <Entry x:Name="DetailsEntry" Placeholder="Details"/>
        
        <Button x:Name="AddBtn" Text="Add" Clicked="AddBtn_OnClicked"/>
    </VerticalStackLayout>
</ContentPage>