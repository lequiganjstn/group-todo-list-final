<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="solo_todo_list.Views.SignInPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Sign In">

    <VerticalStackLayout
        Padding="20"
        BackgroundColor="Black"
        Spacing="20">
        <Image
            HeightRequest="200"
            Source="kleos_logo.png"
            WidthRequest="200" />
        
        <Entry
            x:Name="EmailEntry"
            Placeholder="Email Address"
            TextColor="White" />

        <Entry
            x:Name="PasswordEntry"
            IsPassword="True"
            Placeholder="Password"
            TextColor="White" />

        <Button
            x:Name="SignInBtn"
            BackgroundColor="#d6d6d6"
            Clicked="SignInBtn_Clicked"
            Text="Sign In" 
            TextColor="Black"/>

        <Button
            x:Name="SignUpBtn"
            BackgroundColor="Transparent"
            BorderColor="#d6d6d6"
            BorderWidth="1"
            Clicked="SignUpBtn_Clicked"
            Text="Sign Up"
            TextColor="#d6d6d6" />
    </VerticalStackLayout>
</ContentPage>