<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="solo_todo_list.Views.SignUpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Sign Up">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            BackgroundColor="black"
            Spacing="20">

            <Image
                HeightRequest="200"
                Source="kleos_logo.png"
                WidthRequest="200" />

            <Entry x:Name="NameEntry" Placeholder="User Name" />
            <Entry x:Name="EmailEntry" Placeholder="Email Address" />
            <Entry x:Name="PasswordEntry" Placeholder="Password" />
            <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm Password" />

            <Button
                x:Name="SignUpBtn"
                BackgroundColor="#d6d6d6"
                Clicked="SignUpBtn_Clicked"
                Text="Sign Up" />

            <Button
                x:Name="SignInBtn"
                BackgroundColor="Transparent"
                BorderColor="#d6d6d6"
                BorderWidth="1"
                Clicked="SignInBtn_Clicked"
                Text="Sign In"
                TextColor="#d6d6d6" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
