<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="solo_todo_list.Views.AddTaskPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Add Task">

    <VerticalStackLayout
        Padding="20"
        BackgroundColor="Black"
        Spacing="20">
        <Entry x:Name="TitleEntry" Placeholder="Title" TextColor="White" />

        <Entry x:Name="DetailsEntry" Placeholder="Details" TextColor="White" />

        <Button
            x:Name="AddBtn"
            BackgroundColor="#d6d6d6"
            Clicked="AddBtn_OnClicked"
            Text="Add"
            TextColor="Black"
            VerticalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>