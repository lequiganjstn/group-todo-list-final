<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="solo_todo_list.Views.CompletedPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid Margin="20" RowDefinitions="8*, 2*">
        <ListView
            x:Name="CompletedToDoListView"
            Grid.Row="0"
            ItemSelected="CompletedToDoListView_ItemSelected"
            ItemTapped="CompletedToDoListView_ItemTapped"
            RowHeight="70">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid ColumnDefinitions="4*,*,*" ColumnSpacing="20">
                            <Label
                                Grid.Column="0"
                                Text="{Binding Title}"
                                VerticalOptions="Center" />
                            <Button
                                x:Name="DeleteBtn"
                                Grid.Column="1"
                                Clicked="DeleteBtn_Clicked"
                                CommandParameter="{Binding .}"
                                HeightRequest="50"
                                ImageSource="delete_logo.png"
                                WidthRequest="50" />
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentPage>